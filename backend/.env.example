# AgriGear ERP Backend — Environment Variables
# Copy this to .env and fill in your actual values

# ─── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DB_NAME=agrigear_erp

# ─── JWT ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Frontend URL (used in password reset links) ───────
FRONTEND_URL=http://localhost:3000

# ─── SMTP Email (leave blank to use terminal fallback) ─
# Gmail example: SMTP_SERVER=smtp.gmail.com, SMTP_PORT=587
# Use an App Password, not your main Gmail password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=falldetector91@gmail.com
SMTP_PASSWORD=fosoxthhejjmzwmj
SMTP_FROM_NAME=AgriGear ERP
